<!-- End Google Tag Manager --><!-- =====================================================================
     giffgaff header — self-contained (HTML + CSS + JS).
     For deployment via Squarespace Code Injection → Footer slot.
     Position-fixed at the top of the viewport; pair with the Custom CSS
     snippet that hides the native Squarespace header and adds body
     padding-top to clear the fixed bar.

     Features:
       - Dark header bar with yellow Log in pill (matches your native style)
       - 6 top-level nav items, 5 with light-themed dropdowns + Help link
       - Mobile hamburger → full-screen dark overlay with accordion sections
       - On mobile, Log in icon goes straight to /auth/login (no dropdown)
       - Click-outside / Esc closes dropdowns; Esc also closes the overlay
       - Skip-to-content link for keyboard users
       - Nav items left-aligned next to the logo
       - All nav links open in a new window/tab
     ===================================================================== -->

<style>
  /* Tokens — override to match your design system */
  .gg-header {
    /* Header bar — dark */
    --ggh-bg:           #000000;
    --ggh-fg:           #FFFFFF;
    --ggh-hover:        rgba(255, 255, 255, 0.10);
    --ggh-border:       rgba(255, 255, 255, 0.15);
    --ggh-yellow:       #FFE600;
    --ggh-yellow-hover: #E6CF00;
    /* Dropdown panels — light for readability */
    --ggh-panel-bg:     #FFFFFF;
    --ggh-panel-fg:     #000000;
    --ggh-panel-hover:  #F5F5F5;
    --ggh-panel-border: #E5E5E5;
    --ggh-muted:        rgba(255, 255, 255, 0.60);
    --ggh-font:         "giffgaff", -apple-system, BlinkMacSystemFont, "Segoe UI",
                        Roboto, Helvetica, Arial, sans-serif;
    --ggh-max:          1200px;
    --ggh-z:            9999;
  }

  /* Fixed positioning at top of viewport */
  .gg-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--ggh-bg);
    color: var(--ggh-fg);
    font-family: var(--ggh-font);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  .gg-header *,
  .gg-header *::before,
  .gg-header *::after { box-sizing: border-box; }
  .gg-header a { color: inherit; text-decoration: none; }
  .gg-header a:hover { text-decoration: underline; }
  .gg-header a:focus-visible,
  .gg-header button:focus-visible {
    outline: 2px solid var(--ggh-fg);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .gg-header ul { list-style: none; padding: 0; margin: 0; }
  .gg-header button {
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    color: inherit;
    font: inherit;
    cursor: pointer;
  }

  /* Skip link — visible only when focused */
  .gg-header__skip {
    position: absolute;
    left: 8px;
    top: 8px;
    z-index: calc(var(--ggh-z) + 1);
    padding: 10px 14px;
    background: var(--ggh-fg);
    color: var(--ggh-bg);
    border-radius: 4px;
    transform: translateY(-200%);
    transition: transform .15s;
  }
  .gg-header__skip:focus { transform: none; text-decoration: none; }

  /* Inner row */
  .gg-header__inner {
    max-width: var(--ggh-max);
    margin: 0 auto;
    padding: 30px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 120px;
  }

  /* Logo */
  .gg-header__logo {
    display: inline-flex;
    align-items: center;
    font-size: 26px;
    font-weight: 800;
    line-height: 1;
    color: var(--ggh-fg);
    flex: none;
  }
  .gg-header__logo img,
  .gg-header__logo svg {
    height: 40px;
    width: auto;
    display: block;
  }
  a.gg-header__logo:hover { text-decoration: none; }

  /* Desktop nav — hidden until 1024px */
  .gg-header__nav {
    display: none;
    flex: 1;
  }
  .gg-header__nav > ul {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: flex-start; /* Left-align nav items next to logo */
    padding-left: 16px;          /* Breathing room from the logo */
  }
  .gg-header__item {
    position: relative;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .gg-header__top {
    display: inline-flex;
    align-items: center;
    gap: 0;
    margin: 0;
    padding: 10px 16px;
    border: 0;
    font-size: 15px;
    font-weight: 500;
    border-radius: 4px;
    white-space: nowrap;
    color: var(--ggh-fg);
    transition: background .15s;
  }
  .gg-header__top:hover,
  .gg-header__top[aria-expanded="true"] { background: var(--ggh-hover); text-decoration: none; }
  .gg-header__chev {
    width: 12px;
    height: 12px;
    fill: currentColor;
    transition: transform .15s;
  }
  /* giffgaff.com style: no dropdown indicators on the desktop nav.
     Mobile overlay accordion chevrons are kept (different element). */
  .gg-header__top > .gg-header__chev,
  .gg-header__login > .gg-header__chev { display: none; }

  /* Dropdown menu — light panel */
  .gg-header__menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 240px;
    background: var(--ggh-panel-bg);
    color: var(--ggh-panel-fg);
    border: 1px solid var(--ggh-panel-border);
    border-radius: 8px;
    padding: 8px;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.20);
    display: none;
    z-index: 10;
  }
  .gg-header__top[aria-expanded="true"] + .gg-header__menu,
  .gg-header__login[aria-expanded="true"] + .gg-header__menu { display: block; }
  .gg-header__menu a {
    display: block;
    padding: 10px 12px;
    border-radius: 4px;
    font-size: 14px;
    color: var(--ggh-panel-fg);
  }
  .gg-header__menu a:hover { background: var(--ggh-panel-hover); text-decoration: none; }

  /* Right-side actions */
  .gg-header__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: none;
    position: relative;
  }
  /* Yellow Log in pill */
  .gg-header__login {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 20px 40px;
    background: var(--ggh-yellow);
    color: #000;
    border: 0;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    transition: background .15s;
  }
  .gg-header__login:hover { background: var(--ggh-yellow-hover); color: #000; }
  .gg-header__login svg.gg-header__user { width: 16px; height: 16px; fill: currentColor; }
  .gg-header__login + .gg-header__menu { right: 0; left: auto; color: var(--ggh-panel-fg); }

  /* Burger button — mobile only */
  .gg-header__burger {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: var(--ggh-fg);
  }
  .gg-header__burger:hover { background: var(--ggh-hover); }
  .gg-header__burger svg { width: 22px; height: 22px; fill: currentColor; }

  @media (min-width: 1024px) {
    .gg-header__nav    { display: block; }
    .gg-header__burger { display: none; }
  }
  @media (max-width: 1023px) {
    /* Mobile Log in becomes an icon-only yellow circle that goes to /auth/login */
    .gg-header__login {
      padding: 0;
      width: 40px;
      height: 40px;
      justify-content: center;
      border-radius: 50%;
    }
    .gg-header__login span,
    .gg-header__login .gg-header__chev { display: none; }
    .gg-header__login + .gg-header__menu { display: none !important; }
  }

  /* Mobile overlay — dark to match header */
  .gg-header__overlay {
    position: fixed;
    inset: 0;
    background: var(--ggh-bg);
    color: var(--ggh-fg);
    z-index: var(--ggh-z);
    overflow-y: auto;
    visibility: hidden;
    opacity: 0;
    transition: opacity .2s ease, visibility 0s linear .2s;
  }
  .gg-header__overlay[aria-hidden="false"] {
    visibility: visible;
    opacity: 1;
    transition: opacity .2s ease;
  }
  .gg-header__overlay-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 1px solid var(--ggh-border);
  }
  .gg-header__overlay-close {
    display: inline-flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: var(--ggh-fg);
  }
  .gg-header__overlay-close:hover { background: var(--ggh-hover); }
  .gg-header__overlay-close svg { width: 22px; height: 22px; fill: currentColor; }
  .gg-header__overlay-list { padding: 8px 24px 16px; }
  .gg-header__overlay-list > li { border-bottom: 1px solid var(--ggh-border); }
  .gg-header__overlay-list > li:last-child { border-bottom: 0; }
  .gg-header__overlay-btn,
  .gg-header__overlay-link {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    font-size: 18px;
    font-weight: 600;
    text-align: left;
    color: var(--ggh-fg);
  }
  .gg-header__overlay-link:hover { text-decoration: none; }
  .gg-header__overlay-btn .gg-header__chev { width: 16px; height: 16px; }
  .gg-header__overlay-panel { padding: 4px 0 18px; display: none; }
  .gg-header__overlay-panel li { padding: 6px 0; }
  .gg-header__overlay-panel a { font-size: 16px; font-weight: 400; color: var(--ggh-fg); }
  .gg-header__overlay-list > li:has(.gg-header__overlay-btn[aria-expanded="true"]) .gg-header__overlay-panel {
    display: block;
  }
  .gg-header__overlay-account {
    padding: 16px 24px 40px;
    border-top: 1px solid var(--ggh-border);
  }
  .gg-header__overlay-account h2 {
    margin: 0 0 12px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ggh-muted);
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .gg-header__overlay-account li { padding: 6px 0; }
  .gg-header__overlay-account a { font-size: 16px; color: var(--ggh-fg); }

  /* Body scroll lock when overlay is open (applied via JS) */
  body.gg-no-scroll { overflow: hidden; }
</style>

<div class="gg-header">
  <a class="gg-header__skip" href="#main-content">Skip to main content</a>

  <div class="gg-header__inner">

