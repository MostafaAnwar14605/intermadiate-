    <script defer="true" src="https://static1.squarespace.com/static/vta/5c5a519771c10ba3470d8101/scripts/site-bundle.a373588d45d1d167fb0291ea25487cbe.js" type="text/javascript"></script>
    <script>
  function getYearFromMeta() {
    const meta = document.querySelector('meta[property="article:published_time"]');
    if (meta) return new Date(meta.getAttribute('content')).getFullYear();
    return new Date().getFullYear(); // fallback
  }

  function reformatDates() {
    const months = {
      'Jan':'January','Feb':'February','Mar':'March','Apr':'April',
      'May':'May','Jun':'June','Jul':'July','Aug':'August',
      'Sep':'September','Oct':'October','Nov':'November','Dec':'December'
    };

    // Blog list page — "15/04/2026"
    document.querySelectorAll('time.blog-date').forEach(function(el) {
      const parts = el.textContent.trim().split('/');
      if (parts.length === 3) {
        const date = new Date(parts[2], parts[1] - 1, parts[0]);
        if (!isNaN(date)) {
          el.textContent = date.toLocaleDateString('en-GB', {
            day: 'numeric', month: 'long', year: 'numeric'
          });
        }
      }
    });

    // Article page — "15 Apr" inside a span
    document.querySelectorAll('time.blog-meta-item--date').forEach(function(el) {
      const span = el.querySelector('span');
      if (!span) return;
      const parts = span.textContent.trim().split(' ');
      if (parts.length === 2 && months[parts[1]]) {
        span.textContent = parts[0] + ' ' + months[parts[1]] + ' ' + getYearFromMeta();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', reformatDates);
  window.addEventListener('load', reformatDates);
  setTimeout(reformatDates, 1000);
</script>
<script>
  document.querySelectorAll('a.blog-more-link').forEach(function(el) {
    if (el.textContent.trim() === 'Read More') {
      el.textContent = 'Read more';
    }
  });
</script>
<script>
  function fixLogoLink() {
    const logoLink = document.querySelector('.header-title-logo a');
    if (logoLink) {
      logoLink.href = 'https://giffgaff.com';
      logoLink.target = '_blank'; // remove this line if you want same-tab
      logoLink.rel = 'noopener noreferrer';
    }
  }

  // Run on load and after a short delay to catch Squarespace's JS re-renders
  document.addEventListener('DOMContentLoaded', fixLogoLink);
  window.addEventListener('load', fixLogoLink);
  setTimeout(fixLogoLink, 1000);
</script>

