    <!-- Desktop nav -->
    <nav class="gg-header__nav" aria-label="Main">
      <ul>
        <li class="gg-header__item">
          <button class="gg-header__top" type="button" aria-expanded="false" aria-controls="gghm-join">Join us</button>
          <div class="gg-header__menu" id="gghm-join">
