.gg-footer *::before,
.gg-footer *::after { box-sizing: border-box; }
.gg-footer a { color: inherit; text-decoration: none; }
.gg-footer a:hover { text-decoration: underline; }
.gg-footer a:focus-visible {
  outline: 2px solid var(--gg-fg);
  outline-offset: 3px;
  text-decoration: underline;
}
.gg-footer ul { list-style: none; padding: 0; margin: 0; }

/* --- Main layout: brand column + links grid --------------------------- */
.gg-footer__main {
  max-width: var(--gg-max);
  margin: 0 auto;
  padding: 64px 32px 24px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
}
@media (min-width: 900px) {
  .gg-footer__main { grid-template-columns: 240px 1fr; gap: 64px; }
}

/* --- Brand block (logo + social) -------------------------------------- */
.gg-footer__brand { display: flex; flex-direction: column; gap: 24px; }
.gg-footer__logo {
  font-size: 32px;
  font-weight: 700;
  line-height: 1;
  color: var(--gg-fg);
}
.gg-footer__social { display: flex; flex-wrap: wrap; gap: 8px; }
.gg-footer__social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid var(--gg-fg);
  color: var(--gg-fg);
  transition: background .15s ease, color .15s ease;
}
.gg-footer__social a:hover {
  background: var(--gg-fg);
  color: var(--gg-bg);
  text-decoration: none;
}
.gg-footer__social svg { width: 16px; height: 16px; fill: currentColor; }

/* --- Link columns (3 × 2 on desktop) ---------------------------------- */
.gg-footer__links {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
}
@media (min-width: 600px) {
  .gg-footer__links { grid-template-columns: repeat(3, 1fr); gap: 48px 32px; }
}
.gg-footer__col h3 {
  margin: 0 0 20px;
  font-size: 18px;
  font-weight: 700;
  line-height: 1.3;
  color: var(--gg-fg);
}
.gg-footer__col li { margin-bottom: 14px; }
.gg-footer__col a  { color: var(--gg-fg); font-size: 16px; font-weight: 400; }

/* --- Mobile accordion ------------------------------------------------- */
.gg-footer__col-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: none;
  border: 0;
  padding: 0;
  margin: 0;
  font: inherit;
  font-weight: 700;
  font-size: 18px;
  line-height: 1.3;
  color: inherit;
  text-align: left;
  cursor: pointer;
}
.gg-footer__col-btn:focus-visible {
  outline: 2px solid var(--gg-fg);
  outline-offset: 4px;
  border-radius: 2px;
}
.gg-footer__chev {
  width: 16px;
  height: 16px;
  flex: none;
  margin-left: 12px;
  transition: transform .2s ease;
  fill: currentColor;
}
.gg-footer__col-btn[aria-expanded="false"] .gg-footer__chev { transform: rotate(180deg); }

@media (max-width: 599px) {
  .gg-footer__links    { gap: 0; }
  .gg-footer__col h3   { margin: 0; padding: 18px 0; border-top: 1px solid var(--gg-border); }
  .gg-footer__col:first-child h3 { border-top: 0; }
  .gg-footer__col-panel { padding: 4px 0 18px; display: none; }
  .gg-footer__col:has(.gg-footer__col-btn[aria-expanded="true"]) .gg-footer__col-panel {
    display: block;
  }
}
@media (min-width: 600px) {
  .gg-footer__col-btn { cursor: default; pointer-events: none; }
  .gg-footer__chev    { display: none; }
}

/* --- Bottom rail ------------------------------------------------------ */
.gg-footer__rail {
  max-width: var(--gg-max);
  margin: 0 auto;
  padding: 0 32px;
}
.gg-footer__network {
  margin: 32px 0 0;
  font-size: 17px;
  font-weight: 700;
  color: var(--gg-fg);
}
.gg-footer__sim-cta {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  margin: 28px 0;
  color: var(--gg-fg);
  font-size: 17px;
  font-weight: 500;
}
.gg-footer__sim-cta:hover { text-decoration: none; }
.gg-footer__sim-cta:hover span { text-decoration: underline; }
.gg-footer__sim-icon {
  height: 56px;
  width: auto;
  flex: none;
}
.gg-footer__legal {
  margin: 16px 0 0;
  max-width: 1100px;
  font-size: 13px;
  line-height: 1.7;
  color: var(--gg-muted);
}
.gg-footer__legal a { color: inherit; text-decoration: underline; }
.gg-footer__copy {
  margin: 16px 0 0;
  padding-bottom: 48px;
  font-size: 14px;
  color: var(--gg-fg);
}
</style>

