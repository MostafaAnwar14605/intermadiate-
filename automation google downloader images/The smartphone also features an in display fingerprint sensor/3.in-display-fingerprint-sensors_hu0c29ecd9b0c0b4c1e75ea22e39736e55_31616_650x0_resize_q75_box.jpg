<script>
(function () {
  var header = document.querySelector('.gg-header');
  if (!header) return;

  // --- Desktop dropdowns ----------------------------------------------
  var dropdownButtons = header.querySelectorAll('.gg-header__top, .gg-header__login');

  function closeAllDropdowns(except) {
    dropdownButtons.forEach(function (b) {
      if (b === except) return;
      if (!b.hasAttribute('aria-controls')) return; // Skip navigation-only buttons (Help)
      b.setAttribute('aria-expanded', 'false');
    });
  }

  var loginMobileTarget = 'https://www.giffgaff.com/auth/login';
  var mobileMq = window.matchMedia('(max-width: 1023px)');

  dropdownButtons.forEach(function (b) {
    if (b.tagName !== 'BUTTON') return;
    b.addEventListener('click', function (e) {
      // Navigation-only buttons (e.g. Help) open their data-href in a new tab.
      var navHref = b.getAttribute('data-href');
      if (navHref) {
        window.open(navHref, '_blank', 'noopener,noreferrer');
        return;
      }
      // On mobile, the Log in button has no visible dropdown — send the user
      // straight to the login page (in a new tab) instead of toggling a hidden menu.
      if (b.classList.contains('gg-header__login') && mobileMq.matches) {
        window.open(loginMobileTarget, '_blank', 'noopener,noreferrer');
        return;
      }
      e.stopPropagation();
      var open = b.getAttribute('aria-expanded') === 'true';
      closeAllDropdowns(b);
      b.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  });

  document.addEventListener('click', function (e) {
    if (!header.contains(e.target)) closeAllDropdowns();
  });

  // --- Mobile overlay -------------------------------------------------
  var burger   = header.querySelector('.gg-header__burger');
  var overlay  = header.querySelector('.gg-header__overlay');
  var closeBtn = header.querySelector('.gg-header__overlay-close');

  function openOverlay() {
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'false');
    if (burger) burger.setAttribute('aria-expanded', 'true');
    document.body.classList.add('gg-no-scroll');
  }
  function closeOverlay() {
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'true');
    if (burger) burger.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('gg-no-scroll');
  }

  if (burger) {
    burger.addEventListener('click', function () {
      var open = burger.getAttribute('aria-expanded') === 'true';
      if (open) closeOverlay(); else openOverlay();
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', closeOverlay);

  // Close overlay on any link click inside it
  if (overlay) {
    overlay.addEventListener('click', function (e) {
      if (e.target.tagName === 'A') closeOverlay();
    });
  }

  // --- Mobile overlay accordion sections ------------------------------
  var overlayBtns = header.querySelectorAll('.gg-header__overlay-btn');
  overlayBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      var open = b.getAttribute('aria-expanded') === 'true';
      b.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
  });

  // --- Global keyboard handlers ---------------------------------------
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' || e.key === 'Esc') {
      closeAllDropdowns();
      closeOverlay();
    }
  });
})();
</script><script>Static.COOKIE_BANNER_CAPABLE = true;</script>
